# CipherWeave Environment Variables

# Memgraph connection
CIPHERWEAVE_MEMGRAPH_HOST=localhost
CIPHERWEAVE_MEMGRAPH_PORT=7687

# AWS KMS (leave blank for local dev mock)
CIPHERWEAVE_AWS_REGION=us-east-1
CIPHERWEAVE_KMS_KEY_ID=

# Local dev: use os.urandom instead of real KMS
CIPHERWEAVE_USE_LOCAL_KMS=true

# MCP server
CIPHERWEAVE_SERVER_HOST=0.0.0.0
CIPHERWEAVE_SERVER_PORT=8000

# Security
CIPHERWEAVE_TOKEN_SECRET=change-me-in-production-min-32-chars

# Drift detection
CIPHERWEAVE_DRIFT_WINDOW_SIZE=100

# Logging
CIPHERWEAVE_LOG_LEVEL=INFO
