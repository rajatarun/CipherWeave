# CipherWeave Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Memgraph connection ──────────────────────────────────────────────────────
# Local dev (Docker):
CIPHERWEAVE_MEMGRAPH_HOST=localhost
# Production (contextweave-rag-prod MemgraphPrivateIP):
# CIPHERWEAVE_MEMGRAPH_HOST=172.31.12.134
CIPHERWEAVE_MEMGRAPH_PORT=7687

# ── AWS KMS ──────────────────────────────────────────────────────────────────
CIPHERWEAVE_AWS_REGION=us-east-1
# Production KMS key (KMSKeyArn from contextweave-rag-prod outputs):
CIPHERWEAVE_KMS_KEY_ID=arn:aws:kms:us-east-1:239571291755:key/49eac3db-1f3a-4c91-98ac-61ae722dcaff

# Local dev: skip real KMS, use os.urandom(32) as MSK
CIPHERWEAVE_USE_LOCAL_KMS=true

# ── MCP server (local stdio mode) ────────────────────────────────────────────
CIPHERWEAVE_SERVER_HOST=0.0.0.0
CIPHERWEAVE_SERVER_PORT=8000

# ── Security ─────────────────────────────────────────────────────────────────
# At least 32 random chars. In Lambda, set via Secrets Manager.
CIPHERWEAVE_TOKEN_SECRET=change-me-in-production-min-32-chars

# ── Drift detection ───────────────────────────────────────────────────────────
CIPHERWEAVE_DRIFT_WINDOW_SIZE=100

# ── Logging ───────────────────────────────────────────────────────────────────
CIPHERWEAVE_LOG_LEVEL=INFO

# ── Reference: contextweave-rag-prod CFN outputs ─────────────────────────────
# MemgraphInstanceId:    i-04b2d0f387d2c7d53
# MemgraphPrivateIP:     172.31.12.134
# KMSKeyArn:             arn:aws:kms:us-east-1:239571291755:key/49eac3db-...
# APIEndpoint:           https://56u86rj4qk.execute-api.us-east-1.amazonaws.com/prod
# QueryExpertiseURL:     https://56u86rj4qk.execute-api.us-east-1.amazonaws.com/prod/query-expertise
# PostgresEndpoint:      contextweave-rag-prod-postgresrds-lbglttbevhr9...rds.amazonaws.com
